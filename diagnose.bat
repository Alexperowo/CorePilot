@echo off
chcp 65001 >nul
title CorePilot - сбор диагностики
setlocal

REM ============================================================================
REM  diagnose.bat — собирает диагностику в один файл corepilot_diagnostics.txt.
REM  Дважды кликните, дождитесь окончания, отправьте получившийся .txt
REM  разработчику. Самим разбираться в логах не нужно.
REM ============================================================================

cd /d "%~dp0"

echo ================================================================
echo   CorePilot — сбор диагностики
echo   Это безопасно: скрипт только читает и проверяет, ничего не меняет.
echo ================================================================
echo.

REM Используем Python из venv, если установка была через setup.bat — там стоят
REM все библиотеки. Иначе берём системный Python.
set "PYEXE=python"
if exist "venv\Scripts\python.exe" set "PYEXE=venv\Scripts\python.exe"

"%PYEXE%" --version >nul 2>&1
if errorlevel 1 (
    echo [ОШИБКА] Python не найден. Установите Python 3.12 или запустите setup.bat.
    pause
    exit /b 1
)

"%PYEXE%" diagnose.py

echo.
echo ================================================================
echo   ГОТОВО. Создан файл:  corepilot_diagnostics.txt
echo   Отправьте его разработчику (просто перетащите в чат).
echo ================================================================
echo.
echo Дополнительно: если приложение НЕ запускается, выполните вручную
echo строку ниже и пришлите то, что появится в окне:
echo.
echo     "%PYEXE%" ui_dpg.py
echo.
pause
exit /b 0
