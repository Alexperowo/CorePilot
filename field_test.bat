@echo off
chcp 65001 >nul
title CorePilot - сквозной полевой тест
setlocal

REM ============================================================================
REM  field_test.bat — полностью прогоняет проект (конвейер, демон, ключи,
REM  облачные и локальные модели) и собирает отчёт corepilot_fieldtest.txt.
REM
REM  ВНИМАНИЕ: тест делает РЕАЛЬНЫЕ запросы к облаку (расход квоты/токенов) и
REM  требует запущенных локальных серверов (LM Studio/Ollama), если роли на local.
REM
REM  Двойной клик = бюджет 15 минут. Чтобы задать другой бюджет (в минутах),
REM  запустите из консоли:  field_test.bat 5
REM ============================================================================

cd /d "%~dp0"

echo ================================================================
echo   CorePilot — сквозной полевой тест
echo   Прогоняет конвейер и демон на РЕАЛЬНЫХ моделях. Это расходует
echo   квоту облака. Локальные серверы должны быть запущены.
echo ================================================================
echo.

REM Системный Python (как и весь проект — без venv). Если есть venv — берём его.
set "PYEXE=python"
if exist "venv\Scripts\python.exe" set "PYEXE=venv\Scripts\python.exe"

"%PYEXE%" --version >nul 2>&1
if errorlevel 1 (
    echo [ОШИБКА] Python не найден. Установите Python 3.12.
    pause
    exit /b 1
)

REM Бюджет в минутах: аргумент батника (по умолчанию 15).
set "BUDGET=%~1"
if "%BUDGET%"=="" set "BUDGET=15"

echo Запуск теста (бюджет %BUDGET% мин). Дождитесь надписи ГОТОВО…
echo.
"%PYEXE%" field_test.py %BUDGET%

echo.
echo ================================================================
echo   ГОТОВО. Создан файл:  corepilot_fieldtest.txt
echo   Отправьте его разработчику (просто перетащите в чат).
echo ================================================================
echo.
pause
exit /b 0
